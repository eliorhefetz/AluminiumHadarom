DirectoryIndex index.php index.html

Options -Indexes

ErrorDocument 403 /index.php?error=403
ErrorDocument 404 /index.php?error=404
ErrorDocument 500 /index.php?error=500

RewriteEngine On

RewriteCond %{REQUEST_URI} ^/(https?://(?:www\.)?example\.com)(/.*)?$ [NC]
RewriteRule ^ %2 [R=301,L]

RewriteCond %{REQUEST_URI} ^/https?://(?:www\.)?example\.com/?$ [NC]
RewriteRule ^ / [R=301,L]

RewriteCond %{HTTPS} !=on
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
RewriteRule ^ https://%1%{REQUEST_URI} [L,R=301]

RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.+)/$ $1 [R=301,L]

RewriteCond %{THE_REQUEST} \s/+index(\.php|\.html?)?\s [NC]
RewriteRule ^index(\.php|\.html?)?$ / [R=301,L]

RewriteRule ^$ index.php [L]

RewriteRule ^gallery/?$ index.php [L]

RewriteRule ^feature-location/?$ index.php [L]

RewriteRule ^auth/login/?$ index.php [L]

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.php [L]

<FilesMatch "^(\.env|composer\.(json|lock)|composer\.phar|\.gitignore|\.htaccess)$">
  Require all denied
</FilesMatch>

<FilesMatch "^(package\.json|yarn\.lock|pnpm-lock\.yaml|\.git.*)$">
  Require all denied
</FilesMatch>

RedirectMatch 404 ^/(vendor|node_modules)/.*$

ServerSignature Off
Header unset X-Powered-By

<IfModule mod_setenvif.c>
  SetEnvIfNoCase Request_URI "^/shop/checkout(/|$)" ALLOW_EMBEDDED_PAYMENT=1
  SetEnvIfNoCase Request_URI "^/payment/(success|failed)(?:/)?(?:$|\?)" IS_PAYMENT_RETURN=1
  SetEnvIfNoCase Request_URI "^/(store|item|cart)(/|$)" IS_COMMERCE=1
</IfModule>

<IfModule mod_headers.c>
  Header always set Referrer-Policy "strict-origin-when-cross-origin"

  Header always set X-Frame-Options "DENY" env=!ALLOW_EMBEDDED_PAYMENT
  Header always unset X-Frame-Options env=ALLOW_EMBEDDED_PAYMENT
  Header always unset X-Frame-Options env=IS_PAYMENT_RETURN

  Header always set X-Content-Type-Options "nosniff"
  Header always set Cross-Origin-Opener-Policy "same-origin"

  Header always set Permissions-Policy "geolocation=(), camera=(), microphone=()"

  <If "%{REQUEST_URI} =~ m#^/feature-location(/|$)#">
    Header always unset Permissions-Policy
    Header always set Permissions-Policy "geolocation=(self), camera=(), microphone=()"
  </If>

  <If "%{REQUEST_URI} =~ m#^/feature-camera(/|$)#">
    Header always unset Permissions-Policy
    Header always set Permissions-Policy "geolocation=(self), camera=(self), microphone=()"
  </If>

  <If "%{REQUEST_URI} =~ m#^/admin/example-upload#">
    Header always unset Permissions-Policy
    Header always set Permissions-Policy "geolocation=(), camera=(self), microphone=()"
  </If>

  <If "%{REQUEST_URI} =~ m#^/feature-camera(/|$)#">
    Header always unset Content-Security-Policy
    Header always set Content-Security-Policy "default-src 'self'; \
      script-src 'self' 'unsafe-eval'; \
      style-src 'self'; \
      img-src 'self' data:; \
      font-src 'self'; \
      connect-src 'self'; \
      object-src 'none'; \
      frame-ancestors 'none'; \
      base-uri 'self';"
  </If>

  <If "%{ENV:IS_COMMERCE} == '1'">
    Header always unset Content-Security-Policy
    Header always set Content-Security-Policy "default-src 'self'; \
      script-src 'self' https://tag-manager.example https://ads.example https://adservices.example https://static-assets.example https://social.example; \
      style-src 'self'; \
      img-src 'self' data: https://social.example https://analytics.example https://regional-analytics.example https://adservices.example https://ads.example https://stats.example; \
      connect-src 'self' https://social.example https://analytics.example https://regional-analytics.example https://adservices.example https://ads.example https://stats.example; \
      frame-src 'self' https://tag-manager.example https://analytics.example https://social.example; \
      font-src 'self'; \
      object-src 'none'; \
      frame-ancestors 'none'; \
      base-uri 'self'; \
      form-action 'self' https://social.example; \
      upgrade-insecure-requests"
  </If>

  Header always set Content-Security-Policy "default-src 'self'; \
    script-src 'self' https://tag-manager.example https://ads.example https://adservices.example https://static-assets.example; \
    style-src 'self'; \
    img-src 'self' data: https://analytics.example https://regional-analytics.example https://adservices.example https://ads.example https://stats.example; \
    connect-src 'self' https://analytics.example https://regional-analytics.example https://adservices.example https://ads.example https://stats.example; \
    frame-src 'self' https://tag-manager.example https://analytics.example; \
    font-src 'self'; \
    object-src 'none'; \
    frame-ancestors 'none'; \
    base-uri 'self'; \
    form-action 'self'; \
    upgrade-insecure-requests; \
    require-trusted-types-for 'script'; \
    trusted-types default appHtml appBadgePolicy;" env=!IS_PAYMENT_RETURN env=!IS_COMMERCE

  <If "%{REQUEST_URI} =~ m#^/auth/login#">
    Header always unset Content-Security-Policy
    Header always set Content-Security-Policy "default-src 'self'; \
      script-src 'self'; \
      style-src 'self'; \
      img-src 'self' data:; \
      connect-src 'self'; \
      worker-src 'self'; \
      manifest-src 'self'; \
      object-src 'none'; \
      base-uri 'self'; \
      frame-ancestors 'none'; \
      require-trusted-types-for 'script'; \
      trusted-types login-sw"
  </If>

  <If "%{REQUEST_URI} =~ m#^/shop/checkout(/|$)#">
    Header always unset Content-Security-Policy
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' https://tag-manager.example https://adservices.example https://ads.example https://stats.example; style-src 'self'; img-src 'self' data: https://analytics.example https://regional-analytics.example https://tag-manager.example https://adservices.example https://ads.example https://stats.example; font-src 'self'; connect-src 'self' https://analytics.example https://regional-analytics.example https://tag-manager.example https://secure.payment-provider.example https://*.payment-provider.example https://sandbox.payment-provider.example https://*.sandbox.payment-provider.example https://adservices.example https://ads.example https://stats.example; frame-src 'self' https://tag-manager.example https://secure.payment-provider.example https://*.payment-provider.example https://sandbox.payment-provider.example https://*.sandbox.payment-provider.example; child-src 'self' https://tag-manager.example https://secure.payment-provider.example https://*.payment-provider.example https://sandbox.payment-provider.example https://*.sandbox.payment-provider.example; object-src 'none'; frame-ancestors 'self'; base-uri 'self'; form-action 'self'; upgrade-insecure-requests"
  </If>

  <If "%{REQUEST_URI} =~ m#^/feature-location(/|$)#">
    Header always unset Content-Security-Policy
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self'; img-src 'self' data:; font-src 'self'; connect-src 'self'; worker-src 'self'; manifest-src 'self'; object-src 'none'; base-uri 'self'; frame-ancestors 'none'; trusted-types location-sw"
  </If>

  <If "%{REQUEST_URI} =~ m#^/admin/example-calendar#">
    Header always unset Content-Security-Policy
    Header always set Content-Security-Policy "default-src 'self'; \
      script-src 'self'; \
      style-src 'self' 'unsafe-inline'; \
      img-src 'self' data:; \
      font-src 'self' data:; \
      connect-src 'self' https://calendar-api.example; \
      object-src 'none'; \
      frame-ancestors 'none'; \
      base-uri 'self'; \
      form-action 'self'; \
      upgrade-insecure-requests;"
  </If>

  <If "%{REQUEST_URI} == '/sitemap.xml'">
    Header always unset Content-Security-Policy
    Header always set Content-Security-Policy "default-src 'none'; \
      style-src 'unsafe-inline'; \
      img-src data:; \
      object-src 'none'; \
      base-uri 'none'; \
      frame-ancestors 'none'"
  </If>

  Header always unset Cross-Origin-Opener-Policy env=IS_PAYMENT_RETURN
  Header always unset Content-Security-Policy env=IS_PAYMENT_RETURN

  Header always set Content-Security-Policy "default-src 'self'; \
    script-src 'self' https://tag-manager.example https://adservices.example https://ads.example https://static-assets.example https://identity.example https://social.example; \
    style-src 'self'; \
    img-src 'self' data: https://analytics.example https://regional-analytics.example https://adservices.example https://ads.example https://stats.example https://social.example; \
    connect-src 'self' https://analytics.example https://regional-analytics.example https://adservices.example https://ads.example https://stats.example https://identity.example https://social.example; \
    font-src 'self'; \
    frame-src 'self' https://tag-manager.example https://analytics.example https://regional-analytics.example https://social.example; \
    object-src 'none'; \
    base-uri 'self'; \
    form-action 'self' https://social.example; \
    frame-ancestors 'self' https://secure.payment-provider.example https://*.payment-provider.example https://sandbox.payment-provider.example https://*.sandbox.payment-provider.example; \
    upgrade-insecure-requests" env=IS_PAYMENT_RETURN

  Header always set Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
</IfModule>

Header append Vary "Accept-Encoding,Accept"

<FilesMatch "\.(js|css|jpg|jpeg|png|gif|webp|svg|woff2)$">
  Header set Cache-Control "public, max-age=31536000, immutable"
</FilesMatch>

<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType text/javascript "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresDefault "access plus 7 days"
</IfModule>

<FilesMatch "\.(php)$">
  Header set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
</FilesMatch>

<IfModule mod_brotli.c>
  BrotliCompressionQuality 5
  AddOutputFilterByType BROTLI_COMPRESS \
    text/html text/plain text/css \
    application/javascript application/json application/xml \
    image/svg+xml
</IfModule>

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE \
    text/html text/plain text/css \
    application/javascript application/json application/xml \
    image/svg+xml
</IfModule>

<IfModule mod_rewrite.c>
  RewriteCond %{HTTP_ACCEPT} image/webp
  RewriteCond %{REQUEST_FILENAME} (.+)\.(jpe?g|png)$
  RewriteCond %{DOCUMENT_ROOT}/$1.webp -f
  RewriteRule ^(.+)\.(jpe?g|png)$ $1.webp [T=image/webp,E=accept:1]
</IfModule>

<IfModule mod_mime.c>
  AddType image/webp .webp
  AddType application/manifest+json .webmanifest
</IfModule>

<Files "sw.js">
  Header set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
  Header unset ETag
  FileETag None
  Header set Service-Worker-Allowed "/"
</Files>