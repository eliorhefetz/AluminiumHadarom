{
  "name": "user/aluminiumhadarom",
  "description": "Aluminium Hadarom Website",
  "type": "project",
  "require": {
    "php": ">=8.1",
    "dompdf/dompdf": "^2.0",
    "minishlink/web-push": "^8.0",
    "phpmailer/phpmailer": "^6.10",
    "vlucas/phpdotenv": "^5.6"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    },
    "files": [
      "src/Auth/Security.php",
      "src/Auth/Session.php"
    ]
  },
  "config": {
    "optimize-autoloader": true,
    "sort-packages": true
  },
  "scripts": {
    "post-install-cmd": [
      "@composer dump-autoload -o"
    ],
    "post-update-cmd": [
      "@composer dump-autoload -o"
    ]
  }
}
